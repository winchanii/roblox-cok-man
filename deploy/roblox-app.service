[Unit]
Description=Roblox Account Manager API
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/roblox-account-manager
Environment="PATH=/opt/roblox-account-manager/venv/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"
ExecStart=/opt/roblox-account-manager/venv/bin/uvicorn app.main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
